# ── Conexión al backend ──────────────────────────────────────
# CORRECCIÓN Bug #5: Sin este archivo el flag API_ENABLED = false en todo el
# frontend (AuthContext, RestaurantRepository, FoodRepository, Checkout, etc.)
# lo que hace que NUNCA se llame al backend real: usuarios no se guardan en la
# BD, siempre se carga el restaurante mock de hamburguesas, y los pedidos no
# se persisten.
#
# Coloca este archivo en la RAÍZ del proyecto frontend (junto a package.json).
VITE_USE_BACKEND=true
VITE_API_URL=http://localhost:4000/api
