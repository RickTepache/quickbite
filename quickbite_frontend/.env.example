# ─────────────────────────────────────────────────────────
# QuickBite Frontend — Variables de entorno
# Copia este archivo a `.env` y ajusta los valores.
# ─────────────────────────────────────────────────────────

# URL base de tu backend (sin slash al final)
VITE_API_URL=http://localhost:4000/api

# "true"  → usa el backend real (login, pedidos, menú, admin)
# "false" → usa los datos mock del front (modo demo, sin red)
VITE_USE_BACKEND=true
